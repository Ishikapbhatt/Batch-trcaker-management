# Database
DATABASE_URL=postgresql://username:password@localhost:5432/timp
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=timp
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# External Storage (MinIO/Backblaze B2/Wasabi)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=timp-assets
STORAGE_REGION=us-east-1

# Google Meet
GOOGLE_MEET_CLIENT_ID=your_google_client_id
GOOGLE_MEET_CLIENT_SECRET=your_google_client_secret
GOOGLE_MEET_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Zoom
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@timp.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# AWS (for CloudFront, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net

# Application
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/v1
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
